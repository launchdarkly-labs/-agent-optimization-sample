# LaunchDarkly (env.py aliases these LD_* names to the LAUNCHDARKLY_* names the SDK expects)
LD_SDK_KEY=sdk-your-key-here
LD_API_KEY=api-your-rest-key-here       # REST token with AI Configs write permission (bootstrap.py)
LD_PROJECT_KEY=default

# The Claude agent AND the prompt-writing optimizer (both run on Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# AI-likeness detector (GPTZero). Get a key at https://app.gptzero.me/app/api
AI_LIKENESS_API_KEY=your-gptzero-key-here
